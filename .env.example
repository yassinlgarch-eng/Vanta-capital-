# ============================================================
# Vanta Capital — Environment Variables (مثال)
#
# انسخ هذا الملف إلى ‎.env.local‎ ثم استبدل القيم بمفاتيحك.
#   cp .env.example .env.local
#
# ⚠️  لا تضع المفاتيح الحقيقية داخل المستودع. ‎.env.local‎ مُستثنى تلقائياً.
# ============================================================

# ── أسعار الأسواق ────────────────────────────────────────────
# المزود المدعوم حالياً: finnhub | twelvedata | mock
# عند ضبط القيمة على mock أو ترك المفتاح فارغاً، تُعرض البيانات التجريبية.
MARKET_API_PROVIDER=finnhub
MARKET_API_KEY=your_market_api_key_here

# ── الأخبار ──────────────────────────────────────────────────
# المزود المدعوم حالياً: newsapi | gnews | marketaux | mock
NEWS_API_PROVIDER=newsapi
NEWS_API_KEY=your_news_api_key_here
